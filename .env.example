# ============================================================================
# OpenClaw Cyber-Jianghu MVP 环境变量配置示例
# ============================================================================
#
# 使用方式：
# 1. 复制此文件为 .env
# 2. 根据实际环境修改配置
# 3. 运行: docker compose up -d
#
# 注意：
# - .env 文件不应提交到版本控制（已在.gitignore中）
# - 生产环境请务必修改默认密码
# - 所有配置都可以通过环境变量覆盖
# ============================================================================

# ============================================================================
# 服务端配置
# ============================================================================

# 服务端监听地址
# 0.0.0.0 表示监听所有网卡（Docker容器内使用）
# 127.0.0.1 表示仅本地访问
SERVER_HOST=0.0.0.0

# 服务端监听端口
# 默认: 23333
SERVER_PORT=23333

# 管理员访问凭证 (Dashboard/Config API)
# 如果留空，Server 启动时会自动生成随机 Token 并打印到日志
# 生产环境建议设置固定值
# ADMIN_READ_TOKEN=your_read_token_here
# ADMIN_WRITE_TOKEN=your_write_token_here

# ============================================================================
# 数据库配置 (PostgreSQL)
# ============================================================================

# PostgreSQL连接URL
# 格式: postgres://用户名:密码@主机:端口/数据库名
# Docker环境使用服务名: postgres
# 本地开发使用: localhost
DATABASE_URL=postgres://postgres:changeme@postgres:5432/cyber_jianghu

# PostgreSQL密码
# 生产环境请务必修改！
DB_PASSWORD=changeme

# PostgreSQL端口（宿主机映射端口）
# 默认: 5432
POSTGRES_PORT=5432

# ============================================================================
# 日志配置
# ============================================================================

# 日志级别
# 可选: error, warn, info, debug, trace
# MVP阶段建议: info
# 调试时使用: debug
RUST_LOG=info

# ============================================================================
# 环境标识
# ============================================================================

# 运行环境
# 可选: development, staging, production
ENVIRONMENT=development

# ============================================================================
# MVP阶段说明
# ============================================================================
#
# 以上配置为MVP阶段最小配置，仅包含：
# 1. 服务端基本配置（主机、端口）
# 2. PostgreSQL数据库配置
# 3. 日志级别配置
#
# 注意：
# - Tick引擎配置已迁移至 crates/server/config/game_rules.yaml
# - 时间系统配置已迁移至 crates/server/config/time.yaml
#
# 注意：Redis 在 MVP 阶段暂不需要，将在后续版本引入用于：
# - 状态缓存
# - 分布式锁
# - 消息队列
#
# 未包含的配置（推迟到后续版本）：
# - JWT认证密钥
# - CORS配置
# - 监控指标配置
# - 性能调优参数
# - 多节点配置
# - Redis缓存配置
#
# 常见配置场景：
#
# 场景1: 本地开发（不使用Docker）
# DATABASE_URL=postgres://postgres:changeme@localhost:5432/cyber_jianghu
#
# 场景2: Docker开发环境
# DATABASE_URL=postgres://postgres:changeme@postgres:5432/cyber_jianghu
#
# 场景3: 生产环境
# DB_PASSWORD=<强密码>
# RUST_LOG=warn
# ENVIRONMENT=production
#
# 安全提示：
# 1. 生产环境务必修改DB_PASSWORD
# 2. 不要将.env文件提交到版本控制
# 3. 定期更换密码和密钥
# 4. 使用环境变量或密钥管理服务存储敏感信息
# ============================================================================

# ============================================================================
# 性能调优（可选，MVP阶段使用默认值即可）
# ============================================================================

# PostgreSQL最大连接数（Docker环境）
# POSTGRES_MAX_CONNECTIONS=100

# PostgreSQL共享缓冲区（Docker环境）
# POSTGRES_SHARED_BUFFERS=256MB

# 服务端工作线程数（默认: CPU核心数）
# TOKIO_WORKER_THREADS=4

# ============================================================================
# 调试配置（仅开发环境使用）
# ============================================================================

# 启用详细日志
# RUST_LOG=debug

# 启用SQL查询日志
# SQLX_LOGGING=true

# 启用性能分析
# PROFILING_ENABLED=true
