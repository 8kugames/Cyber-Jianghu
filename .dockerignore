.env
.env.*

# Logs
logs/
*.log

# Temporary files
*.tmp
*.temp
tmp/

# OS files
.DS_Store
Thumbs.db

# Agent data directory (local development)
.claude/
.cyber-jianghu/

# Integration test directories
integration/
