# ============================================================================
# Cyber-Jianghu Agent 环境变量配置
# ============================================================================
#
# 使用方式：
# 1. 复制此文件为 .env
# 2. 修改 AGENT_AUTH_TOKEN（必须从服务端获取）
# 3. 启动服务：docker compose up -d
#
# 注意：
# - .env 文件不应提交到版本控制
# - AGENT_AUTH_TOKEN 必须是有效的 Token
# ============================================================================

# ============================================================================
# Agent 基本配置
# ============================================================================

# Agent 名称（在游戏世界中的角色名）
AGENT_NAME=江湖侠客

# Agent 人设系统提示词
AGENT_SYSTEM_PROMPT=你是一位行走江湖的侠客。

# ============================================================================
# 服务端连接配置
# ============================================================================

# 服务端 WebSocket 地址
# Docker 网络内使用服务名: ws://server:23333/ws
# 本机连接使用: ws://localhost:23333/ws
# 远程连接使用: ws://YOUR_SERVER_IP:23333/ws
AGENT_SERVER_URL=ws://server:23333/ws

# Agent 认证 Token（从服务端注册获取）
# 注意：必须设置有效的 Token，否则 Agent 无法连接服务端
AGENT_AUTH_TOKEN=your_agent_token_here

# ============================================================================
# Agent HTTP API 配置
# ============================================================================

# Agent HTTP API 端口（宿主机映射端口）
# OpenClaw 通过此端口访问 Agent API
# 默认: 23340
AGENT_PORT=23340

# ============================================================================
# 日志配置
# ============================================================================

# 日志级别: error, warn, info, debug, trace
RUST_LOG=info

# ============================================================================
# Agent 访问说明
# ============================================================================
#
# Agent 启动后， OpenClaw 可通过以下地址访问 API：
#
# 本机: http://localhost:23340/api/v1
# Docker 网络内: http://agent:23340/api/v1
#
# Agent API 端点:
# - GET  /api/v1/health        - 健康检查
# - GET  /api/v1/state         - 获取当前世界状态
# - GET  /api/v1/context       - 获取叙事上下文（Markdown，推荐用于 LLM）
# - POST /api/v1/intent        - 提交意图
# - POST /api/v1/validate      - 验证动作
# - GET  /api/v1/relationship  - 关系管理
# - GET  /api/v1/lifespan      - 生命周期状态
# - POST /api/v1/memory        - 记忆管理
#
# ============================================================================
