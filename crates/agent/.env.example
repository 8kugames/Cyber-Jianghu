# ============================================================================
# Cyber-Jianghu Agent 环境变量配置
# ============================================================================
#
# 使用方式：
# 1. 复制此文件为 .env
# 2. 首次启动时，Agent 会自动生成 device_id 并向 Server 注册获取 auth_token
# 3. 身份信息会保存到 ~/.cyber-jianghu/agent.yaml
# 4. 启动服务：docker compose up -d
#
# 注意：
# - .env 文件不应提交到版本控制
# - 设备身份首次启动时自动生成，无需手动配置
# - 角色通过 Web 面板或 CLI 命令创建
# ============================================================================

# ============================================================================
# 服务端连接配置
# ============================================================================

# 服务端 WebSocket 地址
# Docker 网络内使用服务名: ws://server:23333/ws
# 本机连接使用: ws://localhost:23333/ws
# 远程连接使用: ws://YOUR_SERVER_IP:23333/ws
AGENT_SERVER_URL=ws://server:23333/ws

# 服务端 HTTP 地址（用于角色注册等 API 调用）
# Docker 网络内: http://server:23333
# 本机: http://localhost:23333
AGENT_SERVER_HTTP_URL=http://server:23333

# ============================================================================
# Agent HTTP API 配置
# ============================================================================

# Agent HTTP API 端口（WebSocket 主通道 + HTTP API 辅助功能）
# 默认: 23340（可用范围: 23340-23349）
AGENT_PORT=23340

# ============================================================================
# 日志配置
# ============================================================================

# 日志级别: error, warn, info, debug, trace
RUST_LOG=info

# ============================================================================
# Agent 访问说明
# ============================================================================
#
# Agent 启动后，可通过以下地址访问 API：
#
# 本机: http://localhost:23340/api/v1
# Docker 网络内: http://agent:23340/api/v1
#
# Agent API 端点:
# - GET  /api/v1/health              - 健康检查
# - GET  /api/v1/state               - 获取当前世界状态
# - GET  /api/v1/context             - 获取叙事上下文（Markdown，推荐用于 LLM）
# - POST /api/v1/intent              - 提交意图
# - POST /api/v1/validate            - 验证动作
# - GET  /api/v1/relationship/list   - 获取关系列表
# - POST /api/v1/relationship        - 更新关系
# - GET  /api/v1/lifespan            - 生命周期状态
# - POST /api/v1/memory              - 存储记忆
# - POST /api/v1/character/register  - 创建角色（转发到 Server）
#
# Web 面板:
# - http://localhost:23340/panel/    - 角色创建面板
#
# CLI 命令:
# - cyber-jianghu-agent character create <name> [options]
#
# ============================================================================
