# ============================================================================
# Cyber-Jianghu Server 环境变量配置
# ============================================================================
#
# 使用方式：
# 1. 复制此文件为 .env
# 2. 修改 DB_PASSWORD（必须）
# 3. 启动服务：docker compose up -d
#
# 注意：
# - .env 文件不应提交到版本控制
# - 生产环境务必修改默认密码
# ============================================================================

# ============================================================================
# 数据库配置
# ============================================================================

# PostgreSQL 密码（生产环境必须修改！）
DB_PASSWORD=changeme

# PostgreSQL 端口（宿主机映射端口）
# 默认: 5432
POSTGRES_PORT=5432

# ============================================================================
# 服务端配置
# ============================================================================

# 服务端监听端口
# 默认: 23333
SERVER_PORT=23333

# Tick 周期（秒）
# 默认: 60
TICK_DURATION_SECS=60

# 管理后台访问凭证 (Dashboard)
# 如果留空，Server 启动时会自动生成随机 Token 并打印到日志
# ADMIN_READ_TOKEN=your_read_token_here
# ADMIN_WRITE_TOKEN=your_write_token_here

# 游戏客户端只读鉴权 token（可选，未配置时回退 ADMIN_READ_TOKEN）
# 配置后，dashboard READ 端点（require_client_read_token）接受此 token 或 ADMIN_READ_TOKEN
# CLIENT_READ_TOKEN=your_client_read_token_here

# ============================================================================
# 日志配置
# ============================================================================

# 日志级别: error, warn, info, debug, trace
RUST_LOG=info

# 环境标识: development, staging, production
ENVIRONMENT=development
